{
  "redirects": [
    {
      "source": "/",
      "destination": "/Shortlisted%20HTMLS/blenz-v1-contemporary.html",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/Images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.mp4",
      "headers": [
        { "key": "Accept-Ranges", "value": "bytes" },
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
