{
  "redirects": [
    {
      "source": "/",
      "destination": "/blenz-2.0--Contemporary%26bold-A.html",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/Images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.mp4",
